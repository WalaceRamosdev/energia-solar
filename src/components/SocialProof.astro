---
import { Icon } from 'astro-icon/components';

const testimonials = [
  {
    name: "Ricardo Silva",
    role: "Empresário",
    text: "Minha conta de luz na padaria era de R$ 3.500. Hoje pago apenas a taxa mínima. O sistema se pagou em menos de 3 anos. Recomendo muito a SolarMax!",
    image: "https://i.pravatar.cc/150?u=ricardo"
  },
  {
    name: "Ana Paula",
    role: "Dona de Casa",
    text: "Sempre tive medo da instalação estragar o telhado, mas a equipe foi impecável. Tudo limpo e organizado. Agora o ar-condicionado fica ligado o dia todo sem culpa.",
    image: "https://i.pravatar.cc/150?u=ana"
  },
  {
    name: "Marcos Oliveira",
    role: "Produtor Rural",
    text: "A burocracia com a concessionária era o que me travava. A SolarMax resolveu tudo e em 15 dias meu sistema já estava gerando energia. Excelente serviço.",
    image: "https://i.pravatar.cc/150?u=marcos"
  }
];

const partners = [
  "SunPower", "Longi", "Jinko Solar", "Canadian Solar", "Trina Solar"
];
---

<section class="section-padding bg-gray-50 overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-8 md:px-12 lg:px-16">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-emerald-900 font-montserrat mb-4">
        Quem já economiza com a SolarMax
      </h2>
      <p class="text-gray-600 text-lg">
        Mais de 1.500 projetos entregues com satisfação garantida.
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-3 gap-8 mb-20">
      {testimonials.map(t => (
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 relative">
          <Icon name="mdi:format-quote-open" class="absolute top-4 right-4 w-10 h-10 text-emerald-50 opacity-50" />
          <div class="flex items-center space-x-4 mb-6">
            <img src={t.image} alt={t.name} class="w-14 h-14 rounded-full border-2 border-amber-400" />
            <div>
              <h4 class="font-bold text-emerald-900">{t.name}</h4>
              <p class="text-xs text-gray-500">{t.role}</p>
            </div>
          </div>
          <p class="text-gray-600 italic leading-relaxed">"{t.text}"</p>
          <div class="mt-4 flex text-amber-400">
            <Icon name="mdi:star" class="w-4 h-4" />
            <Icon name="mdi:star" class="w-4 h-4" />
            <Icon name="mdi:star" class="w-4 h-4" />
            <Icon name="mdi:star" class="w-4 h-4" />
            <Icon name="mdi:star" class="w-4 h-4" />
          </div>
        </div>
      ))}
    </div>

    <!-- Partners / Authority -->
    <div class="pt-16 border-t border-gray-200">
      <p class="text-center text-sm font-bold text-gray-400 uppercase tracking-widest mb-10">Trabalhamos com as melhores marcas do mundo (Tier 1)</p>
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-50 grayscale">
        {partners.map(p => (
          <span class="text-xl md:text-2xl font-black font-montserrat text-gray-600">{p}</span>
        ))}
      </div>
    </div>

    <!-- Certification Badges -->
    <div class="mt-16 flex flex-wrap justify-center gap-8">
      <div class="flex items-center space-x-2 bg-white px-4 py-2 rounded-lg shadow-sm border border-gray-100">
        <Icon name="mdi:shield-check" class="w-6 h-6 text-emerald-600" />
        <span class="text-sm font-bold text-gray-700">25 Anos de Garantia</span>
      </div>
      <div class="flex items-center space-x-2 bg-white px-4 py-2 rounded-lg shadow-sm border border-gray-100">
        <Icon name="mdi:certificate" class="w-6 h-6 text-emerald-600" />
        <span class="text-sm font-bold text-gray-700">Certificação Inmetro</span>
      </div>
      <div class="flex items-center space-x-2 bg-white px-4 py-2 rounded-lg shadow-sm border border-gray-100">
        <Icon name="mdi:account-hard-hat" class="w-6 h-6 text-emerald-600" />
        <span class="text-sm font-bold text-gray-700">Equipe Própria Especializada</span>
      </div>
    </div>
  </div>
</section>
