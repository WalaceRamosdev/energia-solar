---
import { Icon } from 'astro-icon/components';
---

<section id="calculadora" class="section-padding bg-emerald-900 text-white">
  <div class="max-w-[1400px] mx-auto px-8 md:px-12 lg:px-16">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-3xl md:text-5xl font-bold font-montserrat mb-6">
          Descubra quanto você vai <span class="text-amber-400">economizar</span>
        </h2>
        <p class="text-emerald-100 text-lg mb-8">
          Use nosso simulador inteligente para estimar seu retorno financeiro em 25 anos. O resultado vai te surpreender.
        </p>
        
        <ul class="space-y-4 mb-10">
          <li class="flex items-center space-x-3">
            <Icon name="mdi:check-circle" class="w-6 h-6 text-amber-400" />
            <span>Cálculo baseado na inflação energética real</span>
          </li>
          <li class="flex items-center space-x-3">
            <Icon name="mdi:check-circle" class="w-6 h-6 text-amber-400" />
            <span>Estimativa de ROI (Retorno sobre Investimento)</span>
          </li>
          <li class="flex items-center space-x-3">
            <Icon name="mdi:check-circle" class="w-6 h-6 text-amber-400" />
            <span>Projeção de valorização patrimonial</span>
          </li>
        </ul>
      </div>

      <!-- Calculator Card -->
      <div 
        class="bg-white rounded-3xl p-8 md:p-10 text-gray-900 shadow-2xl"
        x-data="{ 
          conta: 500,
          get economia() { return (this.conta * 12 * 25 * 0.9).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) },
          get investimento() { return (this.conta * 40).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) },
          get roi() { return '3 a 4 anos' }
        }"
      >
        <div class="mb-10">
          <label class="block text-sm font-bold uppercase tracking-wider text-gray-500 mb-4">
            Qual o valor médio da sua conta de luz?
          </label>
          <div class="flex items-center justify-between mb-4">
            <span class="text-3xl font-bold text-emerald-600" x-text="'R$ ' + conta"></span>
          </div>
          <input 
            type="range" 
            min="150" 
            max="5000" 
            step="50" 
            x-model="conta"
            class="w-full h-3 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-emerald-600"
          />
          <div class="flex justify-between text-xs text-gray-400 mt-2">
            <span>R$ 150</span>
            <span>R$ 5.000+</span>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
          <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
            <p class="text-xs font-bold text-gray-400 uppercase mb-1">Economia em 25 anos</p>
            <p class="text-2xl font-bold text-emerald-600" x-text="economia"></p>
          </div>
          <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
            <p class="text-xs font-bold text-gray-400 uppercase mb-1">Retorno (ROI)</p>
            <p class="text-2xl font-bold text-gray-800" x-text="roi"></p>
          </div>
        </div>

        <div class="space-y-4">
          <button class="btn-secondary w-full text-lg py-4 shadow-lg hover:scale-[1.02] transition-transform">
            Receber Estudo de Viabilidade Completo
          </button>
          <p class="text-center text-xs text-gray-400">
            * Valores estimados. Para um orçamento exato, precisamos analisar seu telhado.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
